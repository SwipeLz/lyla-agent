APP_ENV=development
DATABASE_URL=sqlite:///./taskbot.db
GOOGLE_API_KEY=
GOOGLE_ADK_MODEL=gemini-3-flash-preview
DEVICE_API_TOKEN=
TIMEZONE=Asia/Jakarta

# Agent Runtime (Phase 4)
# Pilihan: "real" (Google ADK) atau "fake" (untuk test/CI tanpa GOOGLE_API_KEY).
# Kosongkan untuk auto-select: "real" jika GOOGLE_API_KEY terisi, "fake" jika kosong.
AGENT_MODE=

# Reminder Scheduler (Phase 6)
# Aktifkan APScheduler BackgroundScheduler saat aplikasi start.
# Default: false (test/development tidak start scheduler).
SCHEDULER_ENABLED=false
# Periode antar Scheduler Tick dalam detik. Default: 60.
SCHEDULER_INTERVAL_SECONDS=60

# Dashboard API (Phase 8)
# Pilihan: "none" (tanpa auth, MVP) atau "shared_header" (cek X-Dashboard-Token).
DASHBOARD_AUTH_MODE=none
# Token untuk header X-Dashboard-Token. Hanya dipakai saat DASHBOARD_AUTH_MODE=shared_header.
# Isi nilai rahasia di .env lokal, jangan commit ke git.
DASHBOARD_TOKEN=

# Audio Backend (Phase 10)
# Phase 10 default mode "fake" (hermetic). Phase 11 menambah mode "gemini".
AUDIO_STT_MODE=fake
AUDIO_TTS_MODE=fake
# Transcript yang dikembalikan fake STT (override untuk demo/CI).
FAKE_STT_TRANSCRIPT=catat makan siang 20000
# Batas ukuran upload audio. Decimal MB: 10 MB = 10_000_000 bytes.
MAX_AUDIO_UPLOAD_MB=10
# Format dan sample rate yang dihasilkan fake TTS (silent WAV stdlib).
FAKE_TTS_FORMAT=wav
FAKE_TTS_SAMPLE_RATE=16000

# Audio Backend Phase 11 (real provider via Gemini).
# Hanya dipakai saat AUDIO_STT_MODE=gemini atau AUDIO_TTS_MODE=gemini.
# Reuse GOOGLE_API_KEY di atas; tidak ada credential baru.
AUDIO_STT_PROVIDER_MODEL=gemini-3-flash-preview
AUDIO_TTS_PROVIDER_MODEL=gemini-3.1-flash-tts-preview
AUDIO_TTS_VOICE=Leda
TTS_CACHE_TTL_SECONDS=300

# Phase 12 — dashboard auth + observability (internet-facing).
# Single-user MVP, scrypt-hashed password (stdlib), in-memory sessions.
# Generate DASHBOARD_PASSWORD_SCRYPT with:
#   python -m scripts.hash_dashboard_password
# Empty value = fail-closed (every login attempt 401).
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD_SCRYPT=
SESSION_TTL_HOURS=24
# Set COOKIE_SECURE=false hanya untuk local dev tanpa TLS upstream.
# Local dev di http://localhost wajib false, kalau true browser akan
# membuang cookie lyla_session dan login me-redirect ke /login terus.
# Production di belakang HTTPS reverse proxy: set true.
COOKIE_SECURE=false
# Default ON: ESP wajib kirim X-Device-Token. Matikan hanya saat smoke test lokal.
REQUIRE_DEVICE_TOKEN=true
LOGIN_RATE_LIMIT_MAX_FAILS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
# Public URL backend (di-embed ke config_json saat /devices/pair).
BASE_URL=http://127.0.0.1:8765
# Single-user MVP: pair_device resolves user via this email.
MVP_USER_EMAIL=demo@taskbot.local
