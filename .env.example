APP_ENV=development
DATABASE_URL=sqlite:///./taskbot.db
GOOGLE_API_KEY=
GOOGLE_ADK_MODEL=gemini-3-flash-preview
DEVICE_API_TOKEN=
TIMEZONE=Asia/Jakarta

# Agent Runtime (Phase 4)
# Pilihan: "real" (Google ADK) atau "fake" (untuk test/CI tanpa GOOGLE_API_KEY).
# Kosongkan untuk auto-select: "real" jika GOOGLE_API_KEY terisi, "fake" jika kosong.
AGENT_MODE=

# Reminder Scheduler (Phase 6)
# Aktifkan APScheduler BackgroundScheduler saat aplikasi start.
# Default: false (test/development tidak start scheduler).
SCHEDULER_ENABLED=false
# Periode antar Scheduler Tick dalam detik. Default: 60.
SCHEDULER_INTERVAL_SECONDS=60

# Dashboard API (Phase 8)
# Pilihan: "none" (tanpa auth, MVP) atau "shared_header" (cek X-Dashboard-Token).
DASHBOARD_AUTH_MODE=none
# Token untuk header X-Dashboard-Token. Hanya dipakai saat DASHBOARD_AUTH_MODE=shared_header.
# Isi nilai rahasia di .env lokal, jangan commit ke git.
DASHBOARD_TOKEN=
