# Phase 9 — Frontend environment template.
#
# Copy this file to frontend/.env (gitignored) and fill in the values
# from `python -m scripts.seed_dev`.

# Origin of the FastAPI backend. Default works with `uvicorn app.main:app`
# on its default port. Vite dev-server proxies these paths automatically,
# so for local dev you can leave this as-is.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Demo user UUID printed by `python -m scripts.seed_dev`. Required: the
# dashboard refuses to issue any backend request until this is set.
VITE_DEMO_USER_ID=

# Demo device UUID printed by `python -m scripts.seed_dev`. Optional: when
# blank, the AgentCommandBox warns the user and skips device feedback.
VITE_DEMO_DEVICE_ID=

# Optional shared-header token. Only set this when the backend is configured
# with DASHBOARD_AUTH_MODE=shared_header (see app/config.py). Leave blank for
# the MVP "none" auth mode.
VITE_DASHBOARD_TOKEN=
