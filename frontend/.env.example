# Frontend environment template.
#
# Copy this file to frontend/.env (gitignored) and fill in the values
# from `python -m scripts.seed_dev`.

# Origin of the FastAPI backend. When opening Vite at http://localhost:5173,
# use localhost here too so the session cookie is sent consistently.
VITE_API_BASE_URL=http://localhost:8765

# Demo user UUID printed by `python -m scripts.seed_dev`. Required: the
# dashboard refuses to issue any backend request until this is set.
VITE_DEMO_USER_ID=

# Demo device UUID printed by `python -m scripts.seed_dev`. Optional: when
# blank, the AgentCommandBox warns the user and skips device feedback.
VITE_DEMO_DEVICE_ID=
