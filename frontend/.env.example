# Frontend environment template.
#
# Copy this file to frontend/.env (gitignored) and fill in the values
# from `python -m scripts.seed_dev`.

# Origin of the FastAPI backend.
#
# LOCAL DEV (recommended): leave EMPTY. The Vite dev server proxies all
# backend paths to http://127.0.0.1:8765, so cookies stay same-origin
# and the login redirect loop on http://localhost is avoided.
#
# PRODUCTION (built bundle, deployed behind a reverse proxy): set this
# to the public origin that serves both backend and frontend on the
# same host (e.g. https://lyla.example.com). Leaving it empty in
# production also works when frontend and backend share the origin.
VITE_API_BASE_URL=

# Demo user UUID printed by `python -m scripts.seed_dev`. Required for
# the dashboard's Agent Command box and summary calls.
VITE_DEMO_USER_ID=

# Demo device UUID printed by `python -m scripts.seed_dev`. Optional:
# when blank, the AgentCommandBox warns the user and skips device
# feedback in the response card.
VITE_DEMO_DEVICE_ID=
